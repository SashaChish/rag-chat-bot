{
  "extends": "next/core-web-vitals",
  "rules": {
    "prefer-destructuring": [
      "error",
      {
        "VariableDeclarator": {
          "array": false,
          "object": true
        },
        "AssignmentExpression": {
          "array": true,
          "object": true
        }
      }
    ],
    "no-unsafe-optional-chaining": "error"
  }
}
